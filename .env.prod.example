APP_NAME="asdf.land"
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://asdf.land

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_DATABASE=asdfland
DB_USERNAME=asdfland
DB_PASSWORD=                      # generate a strong password
DB_ROOT_PASSWORD=                 # generate a strong password

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

REVERB_APP_ID=asdfland
REVERB_APP_KEY=                   # openssl rand -hex 16
REVERB_APP_SECRET=                # openssl rand -hex 32
REVERB_HOST=asdf.land
REVERB_PORT=443
REVERB_SCHEME=https

# Baked into the frontend JS bundle at build time
VITE_APP_NAME="asdf.land"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=asdf.land
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
